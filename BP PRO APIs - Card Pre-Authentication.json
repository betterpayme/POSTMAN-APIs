  "item": [
    {
      "name": "Create Pre Auth (MPGS)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "apikey = pm.collectionVariables.get(\"APIKEY\");\r",
              "mid = pm.collectionVariables.get(\"MERCHANTID\");\r",
              "\r",
              "const randomNum = Math.floor(Math.random() * (99999999999999 - 1 + 1)) + 1;\r",
              "pm.globals.set('RandomNum', randomNum);\r",
              "\r",
              "pm.globals.set('mid', mid);\r",
              "\r",
              "data = JSON.parse(request.data);\r",
              "\r",
              "invoice = randomNum;\r",
              "amount = data.max_amount;\r",
              "payment_desc = data.payment_desc;\r",
              "currency = data.currency;\r",
              "purpose = data.purpose;\r",
              "expiry_date = data.expiry_date;\r",
              "\r",
              "var str = apikey + \"|\" + mid +  \"|\" + invoice + \"|\" + amount + \"|\" + payment_desc + \"|\" + currency + \"|\" + expiry_date;\r",
              "\r",
              "console.log(str);\r",
              "\r",
              "//MD5 encryption of STR\r",
              "var strmd5 = CryptoJS.MD5(str).toString();\r",
              "pm.globals.set('hash', strmd5);\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"merchant_id\": \"{{MERCHANTID}}\",\r\n    \"invoice\": \"{{RandomNum}}\",\r\n    \"max_amount\": \"2.50\",\r\n    \"payment_desc\": \"PARKING FEE\",\r\n    \"currency\": \"MYR\",\r\n    \"expiry_date\": \"2026-06-25\",\r\n    \"hash\": \"{{hash}}\",\r\n\r\n    \"baggage_variable\": \"VARIABLE1|VARIABLE2\",\r\n    \"callback_url_be\": \"https://domain.com/your_webhook_endpoint\",\r\n    \"VARIABLE1\": \"VALUE1\",\r\n    \"VARIABLE2\": \"VALUE2\",\r\n    \"checkout_header_title\": \"Merchant Checkout Header Title\",\r\n    \"checkout_header_email\": \"contact@domain.com\",\r\n    \"checkout_header_phone\": \"0312345678\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{API_URL}}/merchant/api/cards/auth/v1/create",
          "host": [
            "{{API_URL}}"
          ],
          "path": [
            "merchant",
            "api",
            "cards",
            "auth",
            "v1",
            "create"
          ]
        }
      },
      "response": []
    },
